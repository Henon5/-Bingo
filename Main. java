    document.body.appendChild(announcement);
    setTimeout(() => { if (announcement) announcement.remove(); resetGameSession(); showLobby(); }, 4000);
}

function startGameCountdownAndPlay() {
    if (!activeGameSession || activeGameSession.winnerDeclared) return;
    activeGameSession.timeLeft = 210;
    activeGameSession.timerInterval = setInterval(() => {
        if (!activeGameSession || activeGameSession.winnerDeclared) return;
        activeGameSession.timeLeft--;
        const mins = Math.floor(activeGameSession.timeLeft / 60);
        const secs = activeGameSession.timeLeft % 60;
        if (document.getElementById('gameTimeLeft')) document.getElementById('gameTimeLeft').innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
        if (activeGameSession.timeLeft <= 0) {
            clearInterval(activeGameSession.timerInterval);
            clearInterval(activeGameSession.intervalId);
            endGameWithWinner(housePlayersInGame[Math.floor(Math.random() * housePlayersInGame.length)], false);
        }
    }, 1000);

    activeGameSession.intervalId = setInterval(() => {
        if (!activeGameSession || activeGameSession.winnerDeclared) return;
        let remaining = Array.from({ length: 75 }, (_, i) => i + 1).filter(n => !activeGameSession.calledNumbers.includes(n));
        if (remaining.length === 0) { endGameWithWinner(housePlayersInGame[Math.floor(Math.random() * housePlayersInGame.length)], false); return; }
        let newNum = remaining[Math.floor(Math.random() * remaining.length)];
        activeGameSession.calledNumbers.push(newNum);
        activeGameSession.currentNumber = newNum;
        if (document.getElementById('currentNumber')) document.getElementById('currentNumber').innerText = newNum;
        if (document.getElementById('calledNumbersCount')) document.getElementById('calledNumbersCount').innerText = activeGameSession.calledNumbers.length;
        let calledSet = new Set(activeGameSession.calledNumbers);
        if (checkBingoOnCard(playerBingoCard, calledSet)) {
            let shouldWin = (gameNumberCounter % 5 === 1);
            if (shouldWin) endGameWithWinner(currentUser, true);
            else endGameWithWinner(housePlayersInGame[Math.floor(Math.random() * housePlayersInGame.length)], false);
        }
    }, 2800);
}

function startGameNow() {
    if (!activeGameSession || activeGameSession.isActive) return;
    isWaitingForPlayers = false;
    activeGameSession.isActive = true;
    activeGameSession.calledNumbers = [];
    document.getElementById('playerCount').innerText = activeGameSession.players.length;
    document.getElementById('gameEntry').innerText = activeGameSession.entryFee + ' Birr';
    document.getElementById('prizePool').innerText = activeGameSession.prizePool;
    playerBingoCard = generateRandomCard();
    renderBingoCard(playerBingoCard);
    hideAllPages();
    document.getElementById('gamePage').classList.remove('hidden');
    startGameCountdownAndPlay();
    showToast(`🔥 Game started with ${activeGameSession.players.length} players! Prize: ${activeGameSession.prizePool} Birr`, 'success');
}

function startWaitingForPlayers(entryAmount) {
    isWaitingForPlayers = true;
    currentEntryAmount = entryAmount;
    gameNumberCounter++;
    currentUser.balance -= entryAmount;
    casinoUsers = casinoUsers.map(u => u.phone === currentUser.phone ? currentUser : u);
    saveLocalData();
    saveUserToPocketBase(currentUser);
    updateUserUI();

    const housePlayerCount = Math.floor(Math.random() * 15) + 8;
    housePlayersInGame = generateRandomHousePlayers(housePlayerCount);
    let allPlayers = [currentUser, ...housePlayersInGame];
    let prizePool = entryAmount * allPlayers.length;

    activeGameSession = {
        isActive: false,
        players: allPlayers.map(p => p.phone),
        playerNames: allPlayers.map(p => ({ name: p.name })),
        entryFee: entryAmount,
        prizePool: prizePool,
        calledNumbers: [],
        currentNumber: null,
        intervalId: null,
        timerInterval: null,
        timeLeft: 210,
        winnerDeclared: false
    };

    document.getElementById('totalPlayersCount').innerText = allPlayers.length;
    document.getElementById('waitingStatus').innerHTML = `✅ ${allPlayers.length} Players Ready! Starting...`;
    const playersList = document.getElementById('activePlayersList');
    if (playersList) {
        playersList.innerHTML = activeGameSession.playerNames.slice(0, 30).map(p =>
            `<span class="player-badge ${p.name === currentUser.name ? '' : 'house'}"><i class="fas ${p.name === currentUser.name ? 'fa-crown' : 'fa-user-circle'}"></i> ${p.name}</span>`
        ).join('');
        if (activeGameSession.playerNames.length > 30) {
            playersList.innerHTML += `<span class="player-badge">+${activeGameSession.playerNames.length - 30} more</span>`;
        }
    }

    setTimeout(() => {
        if (isWaitingForPlayers && activeGameSession && !activeGameSession.isActive) startGameNow();
    }, 3000);
}

function cancelWaiting() {
    if (isWaitingForPlayers && activeGameSession) {
        currentUser.balance += currentEntryAmount;
        casinoUsers = casinoUsers.map(u => u.phone === currentUser.phone ? currentUser : u);
        saveLocalData();
        saveUserToPocketBase(currentUser);
        updateUserUI();
        resetGameSession();
        isWaitingForPlayers = false;
        showToast(`Cancelled. ${currentEntryAmount} Birr refunded.`, 'info');
        showLobby();
    }
}

function resetGameSession() {
    if (activeGameSession?.intervalId) clearInterval(activeGameSession.intervalId);
    if (activeGameSession?.timerInterval) clearInterval(activeGameSession.timerInterval);
    activeGameSession = null;
    isWaitingForPlayers = false;
}

function handleEntry(amount) {
    if (!currentUser || currentUser.isAdmin) { showToast("Login first", 'error'); return; }
    if (currentUser.balance < amount) { showToast(`Need ${amount} Birr`, 'error'); return; }
    if (!currentUser.approved && currentUser.phone !== ADMIN_CRED.phone) { showToast("Pending admin approval", 'warning'); return; }
    if (isWaitingForPlayers || (activeGameSession && activeGameSession.isActive)) { showToast("Game in progress", 'warning'); return; }
    startWaitingForPlayers(amount);
    hideAllPages();
    document.getElementById('lobbyPage').classList.remove('hidden');
    document.getElementById('waitingSection').classList.remove('hidden');
    document.querySelector('.entry-buttons-group').style.display = 'none';
    showToast(`Entered ${amount} Birr. Finding players...`, 'info');
}

function claimBingoManually() {
    if (!activeGameSession || !activeGameSession.isActive || activeGameSession.winnerDeclared) { showToast("No active game", 'error'); return; }
    let calledSet = new Set(activeGameSession.calledNumbers);
    if (checkBingoOnCard(playerBingoCard, calledSet)) {
        let shouldWin = (gameNumberCounter % 5 === 1);
        if (shouldWin) endGameWithWinner(currentUser, true);
        else endGameWithWinner(housePlayersInGame[Math.floor(Math.random() * housePlayersInGame.length)], false);
    } else { showToast("No Bingo yet!", 'warning'); }
}

