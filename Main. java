    if (isPlayerWinner && winner.phone === currentUser?.phone) {
        currentUser.balance += prizeAmount;
        casinoUsers = casinoUsers.map(u => u.phone === currentUser.phone ? currentUser : u);
        let streak = userStreaks[currentUser.phone] || { wins: 0, losses: 0, streak: 0 };
