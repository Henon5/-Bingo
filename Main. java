window.approveWithdraw = (idx) => {
    pendingWithdrawals.splice(idx, 1);
    saveLocalData();
    showAdminDashboard();
    showToast("Withdrawal approved!", 'success');
};

window.adminAddFunds = () => {
    const phone = document.getElementById('fundsPhone')?.value;
    const amount = parseInt(document.getElementById('fundsAmount')?.value);
    let u = casinoUsers.find(u => u.phone === phone);
    if (u && amount > 0) {
        u.balance = (u.balance || 0) + amount;
        saveLocalData();
        showToast(`Added ${amount} Birr to ${u.name}`, 'success');
        showAdminDashboard();
    } else {
        showToast("User not found or invalid amount", 'error');
    }
};

function renderAdminContent(section) {
    if (section === 'dashboard') showAdminDashboard();
}

// ==================== AUTHENTICATION ====================
function handleLogin() {
    console.log("handleLogin called");
    const name = document.getElementById('name').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const pwd = document.getElementById('password').value.trim();
    
    if (!name || !phone || !pwd) { 
        showToast("All fields required", 'error'); 
        return; 
    }
    
    // Admin login
    if (name === ADMIN_CRED.name && phone === ADMIN_CRED.phone && pwd === ADMIN_CRED.password) {
        currentUser = { name, phone, isAdmin: true };
        showAdminDashboard();
        showToast("Welcome Admin!", 'success');
        return;
    }
    
    // Check existing user
    let user = casinoUsers.find(u => u.phone === phone && u.password === pwd);
    
    if (user) {
        if (user.blocked) { 
            showToast("Account blocked", 'error'); 
            return; 
        }
        currentUser = user;
        saveLocalData();
        showLobby();
        updateUserUI();
        showToast(`Welcome ${user.name}!`, 'success');
    } else {
        // Register new user
        let newUser = {
            id: Date.now(),
            name: name,
            phone: phone,
            password: pwd,
            balance: 0,
            wins: 0,
            losses: 0,
            approved: false,
            blocked: false
        };
        casinoUsers.push(newUser);
        currentUser = newUser;
        saveLocalData();
        showLobby();
        updateUserUI();
        showToast("Registered! Wait admin approval.", 'info');
    }
}

function handleLogout() {
    currentUser = null;
    localStorage.removeItem('currentUser');
    resetGameSession();
    hideAllPages();
    const loginPage = document.getElementById('loginPage');
    if (loginPage) loginPage.classList.remove('hidden');
    showToast("Logged out", 'info');
}

// ==================== INITIALIZATION ====================
document.addEventListener('DOMContentLoaded', () => {
    console.log("DOM fully loaded");
    
    // Load data
    loadData();
    
    // Get elements
    const loginBtn = document.getElementById('loginBtn');
    const depositBtn = document.getElementById('depositBtn');
    const withdrawBtn = document.getElementById('withdrawBtnLobby');
    const supportBtn = document.getElementById('supportBtn');
    const logoutBtn = document.getElementById('logoutBtn');
    const cancelGameBtn = document.getElementById('cancelGameBtn');
    const checkBingoBtn = document.getElementById('checkBingoBtn');
    const backToLobbyBtn = document.getElementById('backToLobbyGameBtn');
    const adminLogoutBtn = document.getElementById('adminLogoutBtn');
    const profileBtn = document.getElementById('profileBtn');
    const gameProfileBtn = document.getElementById('gameProfileBtn');
    const gameDepositBtn = document.getElementById('gameDepositBtn');
    
    // Add event listeners
    if (loginBtn) loginBtn.addEventListener('click', handleLogin);
    if (depositBtn) depositBtn.addEventListener('click', showDepositPopup);
    if (withdrawBtn) withdrawBtn.addEventListener('click', showWithdrawPopup);
    if (supportBtn) supportBtn.addEventListener('click', showSupportPopup);
    if (logoutBtn) logoutBtn.addEventListener('click', handleLogout);
    if (cancelGameBtn) cancelGameBtn.addEventListener('click', cancelWaiting);
    if (checkBingoBtn) checkBingoBtn.addEventListener('click', claimBingoManually);
    if (backToLobbyBtn) backToLobbyBtn.addEventListener('click', showLobby);
    if (adminLogoutBtn) adminLogoutBtn.addEventListener('click', () => { currentUser = null; hideAllPages(); document.getElementById('loginPage').classList.remove('hidden'); });
    if (profileBtn) profileBtn.addEventListener('click', showProfilePopup);
    if (gameProfileBtn) gameProfileBtn.addEventListener('click', showProfilePopup);
    if (gameDepositBtn) gameDepositBtn.addEventListener('click', showDepositPopup);
    
    // Entry buttons
    document.querySelectorAll('.entry-button').forEach(btn => {
        btn.addEventListener('click', () => {
            const amount = parseInt(btn.getAttribute('data-entry'));
            handleEntry(amount);
        });
    });
    
    // Nav items
    document.querySelectorAll('.nav-item').forEach(el => {
        if (el.dataset?.section) {
            el.addEventListener('click', () => renderAdminContent(el.dataset.section));
        }
    });
    
    // Update history display
    updateHistoryDisplay();
    
    console.log("Event listeners attached");
});
