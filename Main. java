// ==================== POCKETBASE DATA FUNCTIONS ====================
async function loadDataFromPocketBase() {
    try {
        // Load users
        const usersResult = await pb.collection('users').getFullList();
        if (usersResult.length > 0) {
            casinoUsers = usersResult;
            localStorage.setItem('casinoUsers', JSON.stringify(casinoUsers));
        }
        
        // Load game history
        const historyResult = await pb.collection('game_history').getFullList({ sort: '-created', limit: 20 });
        if (historyResult.length > 0) {
            gameHistory = historyResult.map(h => `${new Date(h.created).toLocaleTimeString()} - 🏆 ${h.winner_name} won ${h.prize_amount} Birr!`);
            localStorage.setItem('gameHistory', JSON.stringify(gameHistory));
        }
        
        // Load streaks
        const streaksResult = await pb.collection('user_streaks').getFullList();
        if (streaksResult.length > 0) {
            streaksResult.forEach(s => { userStreaks[s.user_phone] = { wins: s.wins, losses: s.losses, streak: s.streak }; });
            localStorage.setItem('userStreaks', JSON.stringify(userStreaks));
        }
        
        document.getElementById('serverStatus').innerHTML = `✅ Connected to PocketBase | ${casinoUsers.length} Users`;
        document.getElementById('serverStatus').style.background = 'rgba(42,157,143,0.7)';
    } catch (error) {
        console.error("PocketBase connection error:", error);
        document.getElementById('serverStatus').innerHTML = `⚠️ PocketBase not reachable. Using local storage only.`;
        document.getElementById('serverStatus').style.background = 'rgba(248,197,85,0.7)';
    }
}

async function saveUserToPocketBase(user) {
    try {
        // Check if user exists
        const existing = await pb.collection('users').getFirstListItem(`phone="${user.phone}"`);
        if (existing) {
            await pb.collection('users').update(existing.id, {
                name: user.name,
                balance: user.balance,
                approved: user.approved,
                blocked: user.blocked,
                wins: user.wins,
                losses: user.losses
            });
        }
    } catch {
        // User doesn't exist, create new
        await pb.collection('users').create({
            phone: user.phone,
            name: user.name,
            password: user.password,
            balance: user.balance || 0,
            approved: user.approved || false,
            blocked: user.blocked || false,
            wins: user.wins || 0,
            losses: user.losses || 0
        });
    }
}

async function saveGameHistoryToPocketBase(winnerName, prizeAmount, entryAmount, totalPlayers, gameNumber) {
    try {
        await pb.collection('game_history').create({
            winner_name: winnerName,
            prize_amount: prizeAmount,
            entry_amount: entryAmount,
            total_players: totalPlayers,
            game_number: gameNumber,
            user_phone: currentUser?.phone || ''
        });
    } catch (error) {
        console.error("Error saving game history:", error);
    }
}

async function saveStreakToPocketBase(phone, streak, wins, losses) {
    try {
        const existing = await pb.collection('user_streaks').getFirstListItem(`user_phone="${phone}"`);
        if (existing) {
            await pb.collection('user_streaks').update(existing.id, { streak: streak, wins: wins, losses: losses });
        }
    } catch {
        await pb.collection('user_streaks').create({ user_phone: phone, streak: streak, wins: wins, losses: losses });
    }
}

