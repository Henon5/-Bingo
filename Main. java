    const pendingUsers = casinoUsers.filter(u => !u.approved).length;
    const pendingWithdrawalsCount = pendingWithdrawals.length;
    
    const main = document.getElementById('adminMainContent');
    if (main) {
        main.innerHTML = `
            <div class="dashboard-cards">
                <div class="card"><div class="card-value">${totalUsers}</div><div>Total Users</div></div>
                <div class="card"><div class="card-value">${totalBalance}</div><div>Total Balance</div></div>
                <div class="card"><div class="card-value">${pendingUsers}</div><div>Pending Users</div></div>
                <div class="card"><div class="card-value">${pendingWithdrawalsCount}</div><div>Pending Withdrawals</div></div>
            </div>
            <h3 style="color:var(--accent); margin-top:20px;">⏳ Pending Users</h3>
            ${casinoUsers.filter(u => !u.approved).map(u => `
                <div class="card" style="margin-bottom:10px;">
                    <div><strong>${u.name}</strong> | ${u.phone}</div>
                    <button onclick="approveUser('${u.phone}')">Approve</button>
                </div>
            `).join('') || '<p>No pending users</p>'}
            <h3 style="color:var(--accent); margin-top:20px;">💸 Pending Withdrawals</h3>
            ${pendingWithdrawals.map((w, i) => `
                <div class="card" style="margin-bottom:10px;">
                    <div><strong>${w.name}</strong> | ${w.amount} Birr</div>
                    <button onclick="approveWithdraw(${i})">Approve</button>
                </div>
            `).join('') || '<p>No pending withdrawals</p>'}
            <h3 style="color:var(--accent); margin-top:20px;">💰 Add Funds</h3>
            <input id="fundsPhone" placeholder="Phone Number">
            <input id="fundsAmount" placeholder="Amount" type="number">
            <button onclick="adminAddFunds()">Add Funds</button>
        `;
    }
}

window.approveUser = (phone) => {
    let u = casinoUsers.find(u => u.phone === phone);
    if (u) {
        u.approved = true;
        saveLocalData();
        saveUserToPocketBase(u);
        showAdminDashboard();
        showToast("User approved!", 'success');
    }
};

window.approveWithdraw = (idx) => {
    pendingWithdrawals.splice(idx, 1);
    saveLocalData();
    showAdminDashboard();
    showToast("Withdrawal approved!", 'success');
};

window.adminAddFunds = () => {
    const phone = document.getElementById('fundsPhone')?.value;
    const amount = parseInt(document.getElementById('fundsAmount')?.value);
    let u = casinoUsers.find(u => u.phone === phone);
    if (u && amount > 0) {
        u.balance = (u.balance || 0) + amount;
        saveLocalData();
        saveUserToPocketBase(u);
        showToast(`Added ${amount} Birr to ${u.name}`, 'success');
        showAdminDashboard();
    } else {
        showToast("User not found or invalid amount", 'error');
    }
};

function renderAdminContent(section) {
    if (section === 'dashboard') showAdminDashboard();
}

// ==================== AUTHENTICATION ====================
async function handleLogin() {
    const name = document.getElementById('name').value.trim();
    const phone = document.getElementById('phone').value.trim();
    const pwd = document.getElementById('password').value.trim();
    
    if (!name || !phone || !pwd) { showToast("All fields required", 'error'); return; }
    
    // Admin login
    if (name === ADMIN_CRED.name && phone === ADMIN_CRED.phone && pwd === ADMIN_CRED.password) {
        currentUser = { name, phone, isAdmin: true };
        showAdminDashboard();
        return;
    }
    
    // Check existing user
    let user = casinoUsers.find(u => u.phone === phone && u.password === pwd);
    
    if (user) {
        if (user.blocked) { showToast("Account blocked", 'error'); return; }
        currentUser = user;
        showLobby();
        updateUserUI();
        showToast(`Welcome ${user.name}`, 'success');
    } else {
        // Register new user
        let newUser = {
            id: Date.now(),
            name: name,
            phone: phone,
            password: pwd,
            balance: 0,
            wins: 0,
            losses: 0,
            approved: false,
            blocked: false
        };
        casinoUsers.push(newUser);
        currentUser = newUser;
        saveLocalData();
        saveUserToPocketBase(newUser);
        showLobby();
        updateUserUI();
        showToast("Registered! Wait admin approval.", 'info');
    }
}

function handleLogout() {
    currentUser = null;
    resetGameSession();
    hideAllPages();
    document.getElementById('loginPage').classList.remove('hidden');
    showToast("Logged out", 'info');
}

// ==================== INITIALIZATION ====================
document.addEventListener('DOMContentLoaded', async () => {
    // Load data from PocketBase
    await loadDataFromPocketBase();
    
    // Load local data as fallback
    const savedUsers = localStorage.getItem('casinoUsers');
    if (savedUsers && casinoUsers.length === 0) casinoUsers = JSON.parse(savedUsers);
    const savedWithdrawals = localStorage.getItem('pendingWithdrawals');
    if (savedWithdrawals) pendingWithdrawals = JSON.parse(savedWithdrawals);
    const savedStreaks = localStorage.getItem('userStreaks');
    if (savedStreaks) userStreaks = JSON.parse(savedStreaks);
    const savedHistory = localStorage.getItem('gameHistory');
    if (savedHistory) gameHistory = JSON.parse(savedHistory);
    
    // Event Listeners
    document.getElementById('loginBtn')?.addEventListener('click', handleLogin);
    document.querySelectorAll('.entry-button').forEach(btn => btn.addEventListener('click', () => handleEntry(parseInt(btn.dataset.entry))));
    document.getElementById('depositBtn')?.addEventListener('click', showDepositPopup);
    document.getElementById('withdrawBtnLobby')?.addEventListener('click', showWithdrawPopup);
    document.getElementById('supportBtn')?.addEventListener('click', showSupportPopup);
    document.getElementById('logoutBtn')?.addEventListener('click', handleLogout);
    document.getElementById('cancelGameBtn')?.addEventListener('click', cancelWaiting);
    document.getElementById('checkBingoBtn')?.addEventListener('click', claimBingoManually);
    document.getElementById('backToLobbyGameBtn')?.addEventListener('click', showLobby);
    document.getElementById('adminLogoutBtn')?.addEventListener('click', () => { currentUser = null; hideAllPages(); document.getElementById('loginPage').classList.remove('hidden'); });
    document.querySelectorAll('.nav-item').forEach(el => { if (el.dataset?.section) el.addEventListener('click', () => renderAdminContent(el.dataset.section)); });
    document.getElementById('profileBtn')?.addEventListener('click', showProfilePopup);
    document.getElementById('gameProfileBtn')?.addEventListener('click', showProfilePopup);
    document.getElementById('gameDepositBtn')?.addEventListener('click', showDepositPopup);
    
    // Check for saved user session
    const savedUser = localStorage.getItem('currentUser');
    if (savedUser) {
        try {
            const u = JSON.parse(savedUser);
            if (u && !u.isAdmin) {
                currentUser = u;
                showLobby();
                updateUserUI();
            }
        } catch(e) {}
    }
});
