// ==================== GAME FUNCTIONS ====================
function generateRandomHousePlayers(count) {
    const shuffled = [...ETHIOPIAN_NAMES];
    for (let i = shuffled.length - 1; i > 0; i--) {
        let j = Math.floor(Math.random() * (i + 1));
        [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled.slice(0, count).map((name, idx) => ({ name, phone: `house_${Date.now()}_${idx}`, isHouse: true }));
}

function generateRandomCard() {
    let numbers = Array.from({ length: 75 }, (_, i) => i + 1);
    for (let i = numbers.length - 1; i > 0; i--) {
        let j = Math.floor(Math.random() * (i + 1));
        [numbers[i], numbers[j]] = [numbers[j], numbers[i]];
    }
    let selected = numbers.slice(0, 24);
    let card = [];
    let idx = 0;
    for (let r = 0; r < 5; r++) {
        let row = [];
        for (let c = 0; c < 5; c++) {
            if (r === 2 && c === 2) row.push({ val: 'FREE', called: true });
            else row.push({ val: selected[idx++], called: false });
        }
        card.push(row);
    }
    return card;
}

function renderBingoCard(card) {
    const container = document.getElementById('bingoCard');
    if (!container) return;
    container.innerHTML = '';
    for (let r = 0; r < 5; r++) {
        for (let c = 0; c < 5; c++) {
            let cell = card[r][c];
            let div = document.createElement('div');
            div.className = 'bingo-cell';
            if (cell.val === 'FREE') div.classList.add('free');
            if (cell.called) div.classList.add('called');
            div.innerText = cell.val === 'FREE' ? 'FREE' : cell.val;
            container.appendChild(div);
        }
    }
}

function checkBingoOnCard(card, calledSet) {
    for (let i = 0; i < 5; i++) {
        if (card[i].every(cell => (cell.val === 'FREE') || calledSet.has(cell.val))) return true;
        if (card.every(row => (row[i].val === 'FREE') || calledSet.has(row[i].val))) return true;
    }
    let d1 = true, d2 = true;
    for (let i = 0; i < 5; i++) {
        if (!(card[i][i].val === 'FREE' || calledSet.has(card[i][i].val))) d1 = false;
        if (!(card[i][4 - i].val === 'FREE' || calledSet.has(card[i][4 - i].val))) d2 = false;
    }
    return d1 || d2;
}

function endGameWithWinner(winner, isPlayerWinner) {
