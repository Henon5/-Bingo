    let user = casinoUsers.find(u => u.phone === phone);
    if (user) {
        user.approved = true;
        saveAllData();
        showAdminDashboard();
        showToast("User approved!", 'success');
    }
};

window.approveWithdraw = (idx) => {
    pendingWithdrawals.splice(idx, 1);
    saveAllData();
    showAdminDashboard();
    showToast("Withdrawal approved!", 'success');
};

window.adminAddFunds = () => {
    const phone = document.getElementById('fundsPhone')?.value;
    const amount = parseInt(document.getElementById('fundsAmount')?.value);
    let user = casinoUsers.find(u => u.phone === phone);
    if (user && amount > 0) {
        user.balance = (user.balance || 0) + amount;
        saveAllData();
        showToast(`Added ${amount} Birr to ${user.name}`, 'success');
        showAdminDashboard();
    } else {
        showToast("User not found", 'error');
    }
};

function switchAdminTab(tab) {
    if (tab === 'dashboard') showAdminDashboard();
    else if (tab === 'pending') {
        const content = document.getElementById('adminContent');
        const pending = casinoUsers.filter(u => !u.approved);
        if (content) {
            content.innerHTML = `<h3>Pending Users</h3>${pending.map(u => `
                <div class="card" style="margin-bottom:10px;"><div><strong>${u.name}</strong> | ${u.phone}</div><button onclick="approveUser('${u.phone}')">Approve</button></div>
            `).join('') || '<p>No pending users</p>'}`;
        }
    } else if (tab === 'users') {
        const content = document.getElementById('adminContent');
        if (content) {
            content.innerHTML = `<h3>All Users</h3>${casinoUsers.map(u => `
                <div class="card" style="margin-bottom:10px;"><div><strong>${u.name}</strong> | ${u.phone} | Balance: ${u.balance} Birr | ${u.approved ? '✅' : '⏳'}</div></div>
            `).join('')}`;
        }
    } else if (tab === 'funds') {
        const content = document.getElementById('adminContent');
        if (content) {
            content.innerHTML = `<h3>Add Funds</h3><input id="fundsPhone" placeholder="Phone Number"><input id="fundsAmount" placeholder="Amount" type="number"><button onclick="adminAddFunds()">Add Funds</button>`;
        }
    } else if (tab === 'withdrawals') {
        const content = document.getElementById('adminContent');
        if (content) {
            content.innerHTML = `<h3>Withdrawals</h3>${pendingWithdrawals.map((w, i) => `
                <div class="card" style="margin-bottom:10px;"><div><strong>${w.name}</strong> | ${w.amount} Birr</div><button onclick="approveWithdraw(${i})">Approve</button></div>
            `).join('') || '<p>No pending withdrawals</p>'}`;
        }
    }
}

// ==================== AUTHENTICATION ====================
function handleLogin() {
    const name = document.getElementById('loginName').value.trim();
    const phone = document.getElementById('loginPhone').value.trim();
    const password = document.getElementById('loginPassword').value.trim();
    
    if (!name || !phone || !password) {
        showToast("All fields required", 'error');
        return;
    }
    
    // Admin login
    if (name === ADMIN_CRED.name && phone === ADMIN_CRED.phone && password === ADMIN_CRED.password) {
        currentUser = { name, phone, isAdmin: true };
        showAdminDashboard();
        showToast("Welcome Admin!", 'success');
        return;
    }
    
    // Check existing user
    let user = casinoUsers.find(u => u.phone === phone && u.password === password);
    
    if (user) {
        if (user.blocked) {
            showToast("Account blocked", 'error');
            return;
        }
        currentUser = user;
        saveAllData();
        showLobbyPage();
        updateUserUI();
        showToast(`Welcome back ${user.name}!`, 'success');
    } else {
        // Register new user
        let newUser = {
            id: Date.now(),
            name: name,
            phone: phone,
            password: password,
            balance: 0,
            wins: 0,
            losses: 0,
            approved: false,
            blocked: false
        };
        casinoUsers.push(newUser);
        currentUser = newUser;
        saveAllData();
        showLobbyPage();
        updateUserUI();
        showToast("Registered! Wait admin approval.", 'info');
    }
}

function handleLogout() {
    currentUser = null;
    localStorage.removeItem('currentUser');
    resetGameSession();
    hideAllPages();
    const loginPage = document.getElementById('loginPage');
    if (loginPage) loginPage.classList.remove('hidden');
    showToast("Logged out", 'info');
}

// ==================== INITIALIZATION ====================
document.addEventListener('DOMContentLoaded', () => {
    console.log("Game initializing...");
    loadAllData();
    
    // Login button
    const loginBtn = document.getElementById('doLoginBtn');
    if (loginBtn) loginBtn.addEventListener('click', handleLogin);
    
    // Lobby buttons
    const profileBtn = document.getElementById('lobbyProfileBtn');
    const depositBtn = document.getElementById('lobbyDepositBtn');
    const withdrawBtn = document.getElementById('lobbyWithdrawBtn');
    const supportBtn = document.getElementById('lobbySupportBtn');
    const logoutBtn = document.getElementById('lobbyLogoutBtn');
    const cancelGameBtn = document.getElementById('cancelGameBtn');
    const exitGameBtn = document.getElementById('exitGameBtn');
    const claimBingoBtn = document.getElementById('claimBingoBtn');
    const adminExitBtn = document.getElementById('adminExitBtn');
    
    if (profileBtn) profileBtn.addEventListener('click', showProfilePopup);
    if (depositBtn) depositBtn.addEventListener('click', showDepositPopup);
    if (withdrawBtn) withdrawBtn.addEventListener('click', showWithdrawPopup);
    if (supportBtn) supportBtn.addEventListener('click', showSupportPopup);
    if (logoutBtn) logoutBtn.addEventListener('click', handleLogout);
    if (cancelGameBtn) cancelGameBtn.addEventListener('click', cancelWaiting);
    if (exitGameBtn) exitGameBtn.addEventListener('click', showLobbyPage);
    if (claimBingoBtn) claimBingoBtn.addEventListener('click', claimBingoManually);
    if (adminExitBtn) adminExitBtn.addEventListener('click', () => {
        currentUser = null;
        hideAllPages();
        document.getElementById('loginPage').classList.remove('hidden');
    });
    
    // Entry buttons
    document.querySelectorAll('.entry-button').forEach(btn => {
        btn.addEventListener('click', () => {
            const amount = parseInt(btn.getAttribute('data-entry'));
            handleEntry(amount);
        });
    });
    
    // Admin nav items
    document.querySelectorAll('.admin-nav-item').forEach(item => {
        if (item.getAttribute('data-tab')) {
            item.addEventListener('click', () => {
                document.querySelectorAll('.admin-nav-item').forEach(nav => nav.classList.remove('active'));
                item.classList.add('active');
                switchAdminTab(item.getAttribute('data-tab'));
            });
        }
    });
    
    // If no user is logged in, show login page
    if (!currentUser) {
        hideAllPages();
        document.getElementById('loginPage').classList.remove('hidden');
    } else {
        showLobbyPage();
    }
    
    console.log("Game initialized successfully!");
});
